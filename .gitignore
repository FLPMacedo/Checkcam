# ─── Runtime do CheckCam ─────────────────────────────────────────────────────
# Banco SQLite (popular via `python scripts/seed_db.py`)
*.db
*.db-journal

# Frames JPEG capturados + logs de email (gerados em runtime)
data/

# PDFs e XLSX gerados (saída do checklist)
relatorios/

# Frames de câmera capturados em qualquer lugar (proteção contra base_dir
# mal configurado em alguma instalação — não queremos JPGs vazando no repo).
# JPG só é permitido dentro de assets/ (onde fica o error.jpg).
*.jpg
*.jpeg
!assets/**/*.jpg
!assets/**/*.jpeg
# Pastas de DVR criadas ao lado de main.py se base_dir ficar relativo
DVR_*/
PN_*/
CD_*/
CAMPO_*/

# ─── Binários grandes ────────────────────────────────────────────────────────
# Não versionar — documentar como obter no README:
#   - ffmpeg: baixar de https://www.gyan.dev/ffmpeg/builds/ e extrair em assets/ffmpeg/
#   - playwright: `playwright install chromium` apontando PLAYWRIGHT_BROWSERS_PATH para assets/playwright_browsers/
assets/ffmpeg/
assets/playwright_browsers/

# Logs gerais (caso surjam)
*.log
